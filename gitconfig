[core]
    editor = vim
[user]
	name = Katelyn Faith Baker
	email = kat@generative.vision
[diff]
    tool=vimdiff

[difftool]
    prompt=false

[include]
    path = ~/.gitconfig.local
[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true

[pull]
    rebase = true

[init]
    defaultBranch = main

[format]
    pretty = %C(auto,yellow)%h%C(auto,magenta)% G? %C(auto,blue)%ad %C(auto,green)%<(25,trunc)%aN%C(auto,reset)%s%C(auto,red)% gD% D
